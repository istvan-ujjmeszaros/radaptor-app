# Radaptor App development environment variables
# IMPORTANT: After editing .env, run `docker compose up -d --force-recreate php web`
# so Docker reloads the new values.

# Optional package registry override for first-run bootstrap.
# Leave empty to use the committed default public registry.
RADAPTOR_REGISTRY_URL=
# Optional colon-separated compose files for local wrapper scripts.
# Example for app-local package-dev mode:
# RADAPTOR_DOCKER_COMPOSE_FILES=docker-compose-dev.yml:docker-compose.packages-dev.yml

# Docker Compose project and host port isolation
COMPOSE_PROJECT_NAME=radaptor-app-skeleton-dev
# Standalone default: expose the app on plain localhost.
# For parallel local stacks, override these here.
APP_HTTP_PORT=80
APP_HTTPS_PORT=443
APP_DB_PORT=3308
APP_SWOOLE_PORT=9511
APP_MAILPIT_HTTP_PORT=8026
APP_MAILPIT_SMTP_PORT=1026

# Required services
DB_DEFAULT_DSN=mysql:host=mariadb;port=3306;user=root;password=radaptor_app;dbname=radaptor_app

# Session Redis (required)
SESSION_REDIS_HOST=redis-session
SESSION_REDIS_PORT=6379
SESSION_REDIS_TIMEOUT=2
SESSION_REDIS_TTL=3600
SESSION_REDIS_PREFIX=radaptor-app-skeleton:session:

# Persistent cache Redis (required)
CACHE_REDIS_HOST=redis-cache
CACHE_REDIS_PORT=6379
CACHE_REDIS_TIMEOUT=2

# Application feature toggles
APP_PERSISTENT_CACHE_ENABLED=false
APP_DEFAULT_LOCALE=en-US

# First-run bootstrap credentials
APP_BOOTSTRAP_ADMIN_USERNAME=admin
APP_BOOTSTRAP_ADMIN_PASSWORD=admin123456
APP_BOOTSTRAP_ADMIN_LOCALE=en-US
APP_BOOTSTRAP_ADMIN_TIMEZONE=UTC
